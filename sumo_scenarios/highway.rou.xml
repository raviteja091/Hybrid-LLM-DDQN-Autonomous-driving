<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    
    <!-- Vehicle Type Definitions -->
    <vType id="car_type" accel="2.6" decel="4.5" sigma="0.5" length="5.0" minGap="2.5" maxSpeed="33.33" color="blue" />
    <vType id="ego_type" accel="2.6" decel="4.5" sigma="0.0" length="5.0" minGap="2.5" maxSpeed="33.33" color="red" />
    
    <!-- Route Definition -->
    <route id="route0" edges="highway"/>
    
    <!-- Ego Vehicle (RED, your controlled vehicle) -->
    <vehicle id="ego" type="ego_type" route="route0" depart="0" departSpeed="20" departLane="1" color="red"/>
    
    <!-- Background Traffic (BLUE, randomized) -->
    <flow id="flow_lane0" type="car_type" route="route0" begin="0" end="1000" 
          vehsPerHour="1200" departLane="0" departSpeed="random" departPos="random"/>
    <flow id="flow_lane1" type="car_type" route="route0" begin="0" end="1000" 
          vehsPerHour="1200" departLane="1" departSpeed="random" departPos="random"/>
    <flow id="flow_lane2" type="car_type" route="route0" begin="0" end="1000" 
          vehsPerHour="800"  departLane="2" departSpeed="random" departPos="random"/>
    <flow id="flow_lane3" type="car_type" route="route0" begin="0" end="1000" 
          vehsPerHour="800"  departLane="3" departSpeed="random" departPos="random"/>
    
</routes>
