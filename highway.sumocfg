<configuration>
    <input>
        <net-file value="highway.net.xml"/>
        <route-files value="highway.rou.xml"/>
    </input>
    <time>
        <step-length value="0.1"/>
        <begin value="0"/>
        <end value="4000"/>
    </time>
    <processing>
        <eager-insert value="true"/>
    </processing>
    <report>
        <verbose value="true"/>
        <duration-log value="true"/>
        <no-step-log value="true"/>
    </report>
</configuration>